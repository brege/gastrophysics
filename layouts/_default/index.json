{{- $.Scratch.Add "index" slice -}}
{{- range where site.RegularPages "Sitemap.Disable" "ne" true -}}
    {{- if and (not .Params.searchHidden) (ne .Layout `archives`) (ne .Layout `search`) }}
    {{- $content := .Plain -}}
    {{- $summary := .Summary -}}
    {{- if eq .Type "cv" -}}
        {{- $content = partial "cv/plain.html" . -}}
        {{- $summary = $content | replaceRE `\s+` " " | truncate 320 -}}
    {{- end -}}
    {{- $.Scratch.Add "index" (dict "title" .Title "content" $content "permalink" .Permalink "summary" $summary) -}}
    {{- end }}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
